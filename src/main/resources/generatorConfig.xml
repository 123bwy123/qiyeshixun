<!DOCTYPE generatorConfiguration PUBLIC "-//mybatis.org//DTD MyBatis Generator Configuration 1.0//EN"
        "http://mybatis.org/dtd/mybatis-generator-config_1_0.dtd">
<generatorConfiguration>
    <context id="MySqlContext" targetRuntime="MyBatis3" defaultModelType="flat">
        <property name="javaFileEncoding" value="UTF-8"/>

        <plugin type="org.mybatis.generator.plugins.EqualsHashCodePlugin" />
        <plugin type="org.mybatis.generator.plugins.ToStringPlugin" />

        <commentGenerator>
            <property name="suppressDate" value="true" />
            <property name="addRemarkComments" value="true" />
        </commentGenerator>

        <jdbcConnection driverClass="com.mysql.cj.jdbc.Driver"
                        connectionURL="jdbc:mysql://localhost:3306/qiyeshixun_db?serverTimezone=Asia/Shanghai&amp;useUnicode=true&amp;characterEncoding=utf-8"
                        userId="root"
                        password="123456">
            <property name="nullCatalogMeansCurrent" value="true" />
        </jdbcConnection>

        <javaModelGenerator targetPackage="com.itheima.qiyeshixun.po" targetProject="src/main/java" />

        <sqlMapGenerator targetPackage="mapper" targetProject="src/main/resources" />

        <javaClientGenerator type="XMLMAPPER" targetPackage="com.itheima.qiyeshixun.mapper" targetProject="src/main/java" />

        <table tableName="customer" domainObjectName="Customer"><generatedKey column="id" sqlStatement="MySql" identity="true" /></table>
        <table tableName="system_user" domainObjectName="SystemUser"><generatedKey column="id" sqlStatement="MySql" identity="true" /></table>
        <table tableName="supplier" domainObjectName="Supplier"><generatedKey column="id" sqlStatement="MySql" identity="true" /></table>
        <table tableName="product" domainObjectName="Product"><generatedKey column="id" sqlStatement="MySql" identity="true" /></table>
        <table tableName="warehouse" domainObjectName="Warehouse"><generatedKey column="id" sqlStatement="MySql" identity="true" /></table>
        <table tableName="courier" domainObjectName="Courier"><generatedKey column="id" sqlStatement="MySql" identity="true" /></table>
        <table tableName="purchase_order" domainObjectName="PurchaseOrder"><generatedKey column="id" sqlStatement="MySql" identity="true" /></table>
        <table tableName="purchase_item" domainObjectName="PurchaseItem"><generatedKey column="id" sqlStatement="MySql" identity="true" /></table>
        <table tableName="customer_order" domainObjectName="CustomerOrder"><generatedKey column="id" sqlStatement="MySql" identity="true" /></table>
        <table tableName="order_item" domainObjectName="OrderItem"><generatedKey column="id" sqlStatement="MySql" identity="true" /></table>
        <table tableName="transfer_order" domainObjectName="TransferOrder"><generatedKey column="id" sqlStatement="MySql" identity="true" /></table>
        <table tableName="task_order" domainObjectName="TaskOrder"><generatedKey column="id" sqlStatement="MySql" identity="true" /></table>
        <table tableName="inventory" domainObjectName="Inventory"><generatedKey column="id" sqlStatement="MySql" identity="true" /></table>
        <table tableName="invoice" domainObjectName="Invoice"><generatedKey column="id" sqlStatement="MySql" identity="true" /></table>
    </context>
</generatorConfiguration>